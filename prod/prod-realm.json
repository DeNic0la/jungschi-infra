{
  "realm": "jungschi",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "verifyEmail": false,
  "internationalizationEnabled": true,
  "defaultLocale": "de",
  "supportedLocales": [
    "de",
    "en"
  ],
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "attributes": {
    "userProfileConfiguration": "{\"unmanagedAttributePolicy\":\"DISABLED\",\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"multivalued\":false,\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}}},{\"name\":\"firstName\",\"displayName\":\"Vorname\",\"multivalued\":false,\"required\":{\"roles\":[\"admin\",\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}}},{\"name\":\"lastName\",\"displayName\":\"Nachname\",\"multivalued\":false,\"required\":{\"roles\":[\"admin\",\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}}},{\"name\":\"email\",\"displayName\":\"${email}\",\"multivalued\":false,\"required\":{\"roles\":[\"admin\",\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"email\":{},\"length\":{\"max\":255}}},{\"name\":\"phone_number\",\"displayName\":\"Telefonnummer\",\"multivalued\":false,\"required\":{\"roles\":[\"admin\",\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":32}},\"annotations\":{\"inputType\":\"html5-tel\"}},{\"name\":\"locale\",\"displayName\":\"Sprache\",\"multivalued\":false,\"required\":{\"roles\":[\"admin\",\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"options\":{\"options\":[\"de\",\"en\"]}},\"annotations\":{\"inputType\":\"select\",\"inputOptionLabels\":{\"de\":\"Deutsch\",\"en\":\"English\"}},\"defaultValue\":\"de\"},{\"name\":\"profile_image\",\"displayName\":\"Profilbild\",\"multivalued\":false,\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"uri\":{},\"length\":{\"max\":2048}},\"annotations\":{\"inputType\":\"html5-url\"}}],\"groups\":[]}"
  },
  "roles": {
    "realm": [
      {
        "name": "guardian",
        "description": "Default role for newly registered guardians",
        "composite": false,
        "clientRole": false,
        "containerId": "jungschi"
      },
      {
        "name": "Jungschiteam",
        "description": "Manual realm role for Jungschiteam members",
        "composite": false,
        "clientRole": false,
        "containerId": "jungschi"
      },
      {
        "name": "ADMIN",
        "description": "Manual realm role for administrators",
        "composite": false,
        "clientRole": false,
        "containerId": "jungschi"
      },
      {
        "name": "Sanitaet",
        "description": "1. Hilf",
        "composite": false,
        "clientRole": false,
        "containerId": "jungschi"
      },
      {
        "name": "default-roles-jungschi",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": [
            "guardian"
          ]
        },
        "clientRole": false,
        "containerId": "jungschi"
      }
    ],
    "client": {
      "backend-service": [
        {
          "name": "guardian",
          "description": "Guardian backend-service role",
          "composite": false,
          "clientRole": true,
          "containerId": "backend-service"
        },
        {
          "name": "Jungschiteam",
          "description": "Team backend-service role",
          "composite": false,
          "clientRole": true,
          "containerId": "backend-service"
        },
        {
          "name": "ADMIN",
          "description": "Admin backend-service role",
          "composite": false,
          "clientRole": true,
          "containerId": "backend-service"
        },
        {
          "name": "Sanitaet",
          "description": "Sanitaet backend-service role",
          "composite": false,
          "clientRole": true,
          "containerId": "backend-service"
        }
      ]
    }
  },
  "defaultRole": {
    "name": "default-roles-jungschi",
    "description": "${role_default-roles}",
    "composite": true,
    "clientRole": false,
    "containerId": "jungschi"
  },
  "defaultRoles": [
    "guardian"
  ],
  "users": [],
  "clientScopes": [
    {
      "name": "realm-roles",
      "description": "Expose realm roles in issued tokens for every client",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "app-user-profile",
      "description": "Expose Jungschi user profile attributes in issued tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "phone-number-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "phone_number",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "phone_number",
            "jsonType.label": "String"
          }
        },
        {
          "name": "locale-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "locale",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "locale",
            "jsonType.label": "String"
          }
        },
        {
          "name": "profile-image-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "profile_image",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "profile_image",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "backend-service",
      "name": "Backend Service",
      "description": "Quarkus backend service client for Bearer token authentication",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "realm-roles",
        "app-user-profile",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "redirectUris": [
        "https://app.jungscharluzern.ch/*"
      ],
      "webOrigins": [
        "https://app.jungscharluzern.ch"
      ],
      "protocolMappers": [
        {
          "name": "username-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full-name-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "backend-service",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "backend-service-client-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "usermodel.clientRoleMapping.clientId": "backend-service"
          }
        }
      ]
    },
    {
      "clientId": "frontend-app",
      "name": "Frontend Application",
      "description": "Frontend application client for obtaining tokens",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "realm-roles",
        "app-user-profile",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "redirectUris": [
        "https://app.jungscharluzern.ch/*"
      ],
      "webOrigins": [
        "https://app.jungscharluzern.ch"
      ],
      "protocolMappers": [
        {
          "name": "username-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "firstName-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "lastName-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "phone-number-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "phone_number",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "phone_number",
            "jsonType.label": "String"
          }
        },
        {
          "name": "locale-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "locale",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "locale",
            "jsonType.label": "String"
          }
        },
        {
          "name": "profile-image-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "profile_image",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "profile_image",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "backend-service",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "backend-service-client-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.backend-service.roles",
            "jsonType.label": "String",
            "usermodel.clientRoleMapping.clientId": "backend-service"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "realm-roles",
    "app-user-profile",
    "profile",
    "email"
  ],
  "defaultOptionalClientScopes": [
    "address",
    "phone",
    "offline_access",
    "microprofile-jwt"
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xFrameOptions": "SAMEORIGIN",
    "xRobotsTag": "none",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "accessTokenLifespan": 3600,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5
}
